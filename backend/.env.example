# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Replace with your MongoDB connection string
MONGO_URI=mongodb://localhost:27017/aiRender

# ─── JWT ──────────────────────────────────────────────────
# Use a strong, randomly generated secret in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── Session ──────────────────────────────────────────────
SESSION_SECRET=your_session_secret_change_in_production

# ─── Google OAuth  (FREE - Google Cloud Console) ──────────
# 1. Go to https://console.cloud.google.com/
# 2. Create project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add http://localhost:3000 to Authorized JS origins
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── WebAuthn / Passkeys (100% FREE - W3C Standard) ───────
WEBAUTHN_RP_NAME=aiRender
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ─── Web Push (VAPID Keys - Self Generated, FREE) ─────
# Generate via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@yourcompany.com

# ─── CORS ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── SMTP Email ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="aiRender Video <your_email@gmail.com>"

# ─── JaaS (Jitsi as a Service) ─────────────────────────
JAAS_APP_ID=your_jaas_app_id
JAAS_API_KEY_ID=your_jaas_api_key_id
